{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "claude-SWE-resume-kit",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "runArgs": [
    "--init"
  ],
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer/claude-settings.json,target=/home/vscode/.claude/settings.json,type=bind,consistency=cached",
    "source=/Users/ali/animoto/stack,target=/Users/ali/animoto/stack,type=bind,consistency=cached,readonly"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "james-yu.latex-workshop",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "chat.tools.terminal.autoApprove": {
          "/^command -v( .*)?$/": true,
          "/^node --version$/": true,
          "/^npm --version$/": true,
          "/^pdflatex --version$/": true,
          "/^pdftotext( .*)?$/": true,
          "/^pdfinfo( .*)?$/": true,
          "/^bash scripts\\/safe-run\\.sh/": { "approve": true, "matchCommandLine": true },
          "/^npm install( .*)?$/": false,
          "/^apt-get( .*)?$/": false,
          "/^mv( .*)?$/": false,
          "/^cp( .*)?$/": false,
          "/^git add( .*)?$/": false,
          "/^git (commit|merge|push|reset|rebase)( .*)?$/": false
        },
        "chat.tools.edits.autoApprove": {
          ".devcontainer/devcontainer.json": false,
          ".devcontainer/Dockerfile": false,
          ".devcontainer/claude-settings.json": false,
          "scripts/safe-run.sh": false,
          "scripts/generate_claude_settings.js": false
        },
        "chat.tools.subagent.autoApprove": true
      }
    }
  },
  "postCreateCommand": "bash /workspaces/claude-SWE-resume-kit/.devcontainer/init-copilot-hooks.sh && node /workspaces/claude-SWE-resume-kit/scripts/generate_claude_settings.js && pdflatex --version && node --version && python3 --version",
  "postAttachCommand": "bash /workspaces/claude-SWE-resume-kit/.devcontainer/init-copilot-hooks.sh && node /workspaces/claude-SWE-resume-kit/scripts/generate_claude_settings.js"
}
