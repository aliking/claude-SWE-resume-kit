{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node ./scripts/hooks/pretooluse_terminal_policy_guard.js",
        "timeout": 10
      }
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(command -v)",
      "Bash(command -v *)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(pdflatex --version)",
      "Bash(pdftotext)",
      "Bash(pdftotext *)",
      "Bash(pdfinfo)",
      "Bash(pdfinfo *)",
      "Bash(bash scripts\\/safe-run.sh)"
    ],
    "ask": [
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(apt-get)",
      "Bash(apt-get *)",
      "Bash(mv)",
      "Bash(mv *)",
      "Bash(cp)",
      "Bash(cp *)",
      "Bash(git add)",
      "Bash(git add *)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git merge)",
      "Bash(git merge *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git reset)",
      "Bash(git reset *)",
      "Bash(git rebase)",
      "Bash(git rebase *)"
    ],
    "deny": [
      "Write(.devcontainer/devcontainer.json)",
      "Edit(.devcontainer/devcontainer.json)",
      "Write(.devcontainer/Dockerfile)",
      "Edit(.devcontainer/Dockerfile)",
      "Write(.devcontainer/claude-settings.json)",
      "Edit(.devcontainer/claude-settings.json)",
      "Write(scripts/safe-run.sh)",
      "Edit(scripts/safe-run.sh)",
      "Write(scripts/generate_claude_settings.js)",
      "Edit(scripts/generate_claude_settings.js)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "enableWeakerNestedSandbox": true,
    "filesystem": {
      "allowWrite": [
        "./",
        "/tmp"
      ],
      "denyRead": [
        "~/.aws/credentials",
        "~/.gnupg/**",
        "~/.ssh/**"
      ]
    }
  }
}
