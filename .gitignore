.planning/

# Personal/local config
/config.md

# Knowledge base: ignore data, keep folder structure and explicit templates/examples
/knowledge_base/**
!/knowledge_base/
!/knowledge_base/**/
!/knowledge_base/**/.gitkeep
!/knowledge_base/extractions/_INVENTORY.template.md

# JDs: ignore everything, keep only example JD
/JDs/*
!/JDs/example_jd.txt

# Session-specific (users may want to keep these — uncomment to ignore)
# output/
